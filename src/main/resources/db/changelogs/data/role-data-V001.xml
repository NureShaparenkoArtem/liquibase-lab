<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <!-- USER SERVICE | Author: shaparenko | Branch: user_service-data -->

    <changeSet id="101-insert-role-data" author="shaparenko">

        <preConditions onFail="HALT">
            <and>
                <tableExists tableName="role"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM role WHERE name = 'ADMIN'
                </sqlCheck>
            </and>
        </preConditions>

        <sql>
            INSERT INTO role (name, description) VALUES
            ('ADMIN', 'Full system access'),
            ('CASHIER', 'Can sell and validate tickets'),
            ('VIEWER', 'Regular cinema visitor');
        </sql>

        <rollback>
            <sql>DELETE FROM role WHERE name IN ('ADMIN', 'CASHIER', 'VIEWER');</sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
