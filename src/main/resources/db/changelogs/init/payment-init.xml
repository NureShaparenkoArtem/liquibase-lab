<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <!-- TICKET SERVICE | Author: shaparenko | Branch: ticket_service-feature -->

    <changeSet id="008-create-payment-table" author="shaparenko">

        <preConditions onFail="HALT">
            <tableExists tableName="ticket"/>
        </preConditions>

        <createTable tableName="payment">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="ticket_id" type="BIGINT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="amount" type="DECIMAL(8,2)">
                <constraints nullable="false"/>
            </column>
            <column name="method" type="VARCHAR(30)" defaultValue="CARD"
                    remarks="CARD, CASH, ONLINE"/>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING"
                    remarks="PENDING, SUCCESS, FAILED"/>
            <column name="paid_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="payment" baseColumnNames="ticket_id"
                referencedTableName="ticket" referencedColumnNames="id"
                constraintName="fk_payment_ticket"
                onDelete="CASCADE"/>

        <sql>CREATE UNIQUE INDEX uq_payment_ticket_id ON payment(ticket_id);</sql>

        <sql>
            INSERT INTO tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'payment', 'DATA_TABLE', 'shaparenko', 1, 'ticket_service',
                    'Payment records for each sold ticket',
                    (SELECT COUNT(*) FROM information_schema.columns
                     WHERE table_schema = 'public' AND table_name = 'payment'),
                    NOW(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM tables WHERE name = 'payment';</sql>
            <dropTable tableName="payment"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
