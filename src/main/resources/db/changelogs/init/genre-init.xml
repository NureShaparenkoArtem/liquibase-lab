<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <!-- MOVIE SERVICE | Author: shaparenko | Branch: movie_service-feature -->

    <changeSet id="003-create-genre-table" author="shaparenko">
        <createTable tableName="genre">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="VARCHAR(300)"/>
        </createTable>

        <sql>CREATE INDEX idx_genre_name ON genre(name);</sql>

        <sql>
            INSERT INTO tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'genre', 'DATA_TABLE', 'shaparenko', 1, 'movie_service',
                    'Movie genres: Action, Drama, Comedy, etc.',
                    (SELECT COUNT(*) FROM information_schema.columns
                     WHERE table_schema = 'public' AND table_name = 'genre'),
                    NOW(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM tables WHERE name = 'genre';</sql>
            <dropTable tableName="genre"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
